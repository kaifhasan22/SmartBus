  "components": {
    "schemas": {
      "BroadcastNotificationRequest": {
        "required": [
          "Message",
          "Role",
          "Title"
        ],
        "type": "object",
        "properties": {
          "Role": {
            "minLength": 1,
            "type": "string"
          },
          "Title": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "Message": {
            "maxLength": 500,
            "minLength": 1,
            "type": "string"
          },
          "Type": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateBusRequest": {
        "required": [
          "BusNumber",
          "LicensePlate"
        ],
        "type": "object",
        "properties": {
          "BusNumber": {
            "maxLength": 20,
            "minLength": 1,
            "type": "string"
          },
          "LicensePlate": {
            "maxLength": 20,
            "minLength": 1,
            "type": "string"
          },
          "CapacitySeats": {
            "type": "integer",
            "format": "int32"
          },
          "AssignedDriverId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "AssignedRouteId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateRouteRequest": {
        "required": [
          "RouteName",
          "ScheduledEnd",
          "ScheduledStart"
        ],
        "type": "object",
        "properties": {
          "RouteName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "Description": {
            "type": "string",
            "nullable": true
          },
          "ScheduledStart": {
            "minLength": 1,
            "type": "string"
          },
          "ScheduledEnd": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateStopRequest": {
        "required": [
          "Latitude",
          "Longitude",
          "StopName",
          "StopOrder"
        ],
        "type": "object",
        "properties": {
          "StopName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "Latitude": {
            "type": "number",
            "format": "double"
          },
          "Longitude": {
            "type": "number",
            "format": "double"
          },
          "StopOrder": {
            "type": "integer",
            "format": "int32"
          },
          "LandmarkNote": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "EndTripRequest": {
        "type": "object",
        "properties": {
          "Notes": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LocationUpdateRequest": {
        "required": [
          "BusId",
          "Latitude",
          "Longitude",
          "TripId"
        ],
        "type": "object",
        "properties": {
          "BusId": {
            "type": "integer",
            "format": "int32"
          },
          "TripId": {
            "type": "integer",
            "format": "int32"
          },
          "Latitude": {
            "maximum": 90,
            "minimum": -90,
            "type": "number",
            "format": "double"
          },
          "Longitude": {
            "maximum": 180,
            "minimum": -180,
            "type": "number",
            "format": "double"
          },
          "SpeedKmph": {
            "type": "number",
            "format": "double"
          },
          "HeadingDegrees": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "AccuracyMeters": {
            "type": "number",
            "format": "double",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "required": [
          "Email",
          "Password"
        ],
        "type": "object",
        "properties": {
          "Email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "Password": {
            "minLength": 6,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RegisterRequest": {
        "required": [
          "Email",
          "Name",
          "Password",
          "Role"
        ],
        "type": "object",
        "properties": {
          "Name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "Email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "Password": {
            "minLength": 6,
            "type": "string"
          },
          "Role": {
            "minLength": 1,
            "type": "string"
          },
          "PhoneNumber": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SendNotificationRequest": {
        "required": [
          "Message",
          "Title",
          "UserId"
        ],
        "type": "object",
        "properties": {
          "UserId": {
            "type": "integer",
            "format": "int32"
          },
          "Title": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "Message": {
            "maxLength": 500,
            "minLength": 1,
            "type": "string"
          },
          "Type": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "StartTripRequest": {
        "required": [
          "BusId",
          "RouteId"
        ],
        "type": "object",
        "properties": {
          "BusId": {
            "type": "integer",
            "format": "int32"
          },
          "RouteId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "UpdateBusRequest": {
        "type": "object",
        "properties": {
          "BusNumber": {
            "type": "string",
            "nullable": true
          },
          "LicensePlate": {
            "type": "string",
